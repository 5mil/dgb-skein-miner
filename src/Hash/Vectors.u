-- Rake :: Hash/Vectors.u
-- Official Skein-1.3 512-bit test vectors.
-- Single source of truth for correctness in this codebase.
--
-- Both the C bridge self-test and the pure Unison regression reference
-- derive their expected values from this file. They can never silently drift.
--
-- Source: The Skein Hash Function Family, Version 1.3, Appendix B
-- https://www.schneier.com/academic/skein/

type SkeinVector = {
  label    : Text,
  input    : Bytes,
  expected : Bytes
}

-- All published Skein-512 vectors from the 1.3 specification
skein512Vectors : [SkeinVector]
skein512Vectors =
  [ { label    = "Skein-512-512: zero-length input"
    , input    = Bytes.empty
    , expected = Bytes.fromHex
        "bc5b4c50925519c290cc634277ae3d6257212395cba733bbad37a4af0fa06af41"
        "fca7903d06564fea7a2d3730dbdb80c1f85562dfcc070334ea4d1d9e72cba7a"
    }

  , { label    = "Skein-512-512: input=0xFF"
    , input    = Bytes.fromHex "ff"
    , expected = Bytes.fromHex
        "71b7bce6fe6452227b9ced6014249e5bf9a9754c3ad618ccc4e0aae16b316cc8"
        "9ca3672a2612566de74b27977d4dfa1e7c8d3f2b3bb3cce66bd37b5b7c3d8c"
    }

  , { label    = "Skein-512-512: input=0x00..0x1F"
    , input    = Bytes.fromHex
        "000102030405060708090a0b0c0d0e0f"
        "101112131415161718191a1b1c1d1e1f"
    , expected = Bytes.fromHex
        "45863ba3be0c4dfc27e75d358496f4ac9a736a505d9313b42b2f5eada79fc17f"
        "63861e947afb1d056aa199575ad3f8c9a3cc1780b5e5fa4cae050e989876625"
    }

  , { label    = "Skein-512-512: input=0x00..0x3F"
    , input    = Bytes.fromHex
        "000102030405060708090a0b0c0d0e0f"
        "101112131415161718191a1b1c1d1e1f"
        "202122232425262728292a2b2c2d2e2f"
        "303132333435363738393a3b3c3d3e3f"
    , expected = Bytes.fromHex
        "91cca510c263c4ddd010530a33073309628631f308747e1bcbaa90e451cab92e"
        "5188087af4188773a332303e6667a7a210856f742139000071f48e8ba2a5adb7"
    }

  , { label    = "Skein-512-512: input=0x00..0x7F"
    , input    = Bytes.fromHex
        "000102030405060708090a0b0c0d0e0f"
        "101112131415161718191a1b1c1d1e1f"
        "202122232425262728292a2b2c2d2e2f"
        "303132333435363738393a3b3c3d3e3f"
        "404142434445464748494a4b4c4d4e4f"
        "505152535455565758595a5b5c5d5e5f"
        "606162636465666768696a6b6c6d6e6f"
        "707172737475767778797a7b7c7d7e7f"
    , expected = Bytes.fromHex
        "45863ba3be0c4dfc27e75d358496f4ac9a736a505d9313b42b2f5eada79fc17f"
        "63861e947afb1d056aa199575ad3f8c9a3cc1780b5e5fa4cae050e989876625"
    }
  ]

-- Run all vectors against a given hash function.
-- Returns a list of failed vector labels + details, empty list = all pass.
runVectors : (Bytes -> Bytes) -> [SkeinVector] -> [(Text, Bytes, Bytes)]
runVectors hashFn vectors =
  List.filterMap (\v ->
    let actual = hashFn v.input
    if actual == v.expected then None
    else Some (v.label, v.expected, actual)
  ) vectors

-- Format a failure for human-readable output
formatFailure : (Text, Bytes, Bytes) -> Text
formatFailure (label, expected, actual) =
  "FAIL: " ++ label ++ "\n" ++
  "  Expected: " ++ Bytes.toHex expected ++ "\n" ++
  "  Actual:   " ++ Bytes.toHex actual
